# ALLUR — environment variables
# Copy to .env for local dev, and set these in Vercel Project Settings → Environment Variables.
# Nothing here is required for the app to boot; missing values just disable the
# related feature (AI, billing, email) and fall back to safe defaults.

# ── Database (required) ─────────────────────────────────────────────
# Vercel Postgres provides this automatically when you add the integration.
# For local dev use any Postgres connection string.
DATABASE_URL=postgres://user:password@host:5432/dbname

# ── Public URL ──────────────────────────────────────────────────────
# Stable public origin used for password-reset links and Stripe redirects.
# On Vercel you can leave this unset (VERCEL_URL is used), but setting it to your
# production domain is recommended so links don't point at per-deploy URLs.
APP_URL=https://your-app.vercel.app

# ── OpenAI (required for AI coach / vision / voice) ─────────────────
OPENAI_API_KEY=sk-...
# Optional: override the chat/vision model (default: gpt-4o)
# OPENAI_CHAT_MODEL=gpt-4o
# Optional: custom base URL (e.g. a proxy). Leave unset for api.openai.com.
# OPENAI_BASE_URL=

# ── Stripe (required for subscriptions/billing) ─────────────────────
STRIPE_SECRET_KEY=sk_live_or_test_...
# Create a webhook in the Stripe dashboard pointing to:
#   {APP_URL}/api/stripe/webhook
# then paste its signing secret here.
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Admin allowlist ─────────────────────────────────────────────────
# Comma-separated emails that get the /admin console + unlimited (Premium) access.
# The account must already own that email. Requires a redeploy to change.
ADMIN_EMAILS=you@example.com

# ── Email / password reset (optional) ───────────────────────────────
# SMTP works with Gmail app-passwords, Resend, Postmark, SES, etc.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=apikey-or-username
SMTP_PASS=your-smtp-password
EMAIL_FROM="ALLUR <no-reply@your-domain.com>"
