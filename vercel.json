{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "pnpm install --no-frozen-lockfile",
  "buildCommand": "pnpm run vercel-build",
  "outputDirectory": "artifacts/fitcoach/dist/public",
  "framework": null,
  "functions": {
    "api/index.mjs": {
      "maxDuration": 60,
      "includeFiles": "artifacts/api-server/dist/migrations/**"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/weekly-recap",
      "schedule": "0 16 * * 1"
    }
  ]
}